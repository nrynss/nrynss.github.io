{
  "name": "nryn-comments-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.toml",
    "deploy": "wrangler deploy -c wrangler.toml",
    "db:create": "wrangler d1 create nryn-dev-comments-db",
    "db:schema": "wrangler d1 execute nryn-dev-comments-db --remote --file=../schema.sql -c wrangler.toml"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "wrangler": "^4.105.0"
  }
}
