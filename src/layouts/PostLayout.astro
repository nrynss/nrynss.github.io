---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';
import CommentList from '../components/interactive/CommentList.svelte';
import CommentForm from '../components/interactive/CommentForm.svelte';

interface Props {
  id: string;
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
}

const { id, title, description, date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout title={title} description={description}>
  <article class="post-single">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {description && <div class="post-description">{description}</div>}
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <div class="post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="post-footer">
        <ul class="post-tags">
          {tags.map((tag) => (
            <li>
              <a href={`/tags/${tag}/`}>{tag}</a>
            </li>
          ))}
        </ul>
      </footer>
    )}

    <!-- Client-side comments list + form, backed by the standalone comments Worker -->
    <div class="comments-section">
      <h3>Comments</h3>
      <CommentList post={id} client:visible />

      <CommentForm post={id} client:visible />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Ensure the comments-section uses the exact custom classes from custom.css */
  .comments-section {
    margin-top: 3rem;
    border-top: 1px solid var(--border, #e0e0e0);
    padding-top: 2rem;
  }
  .comments-section h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
  }
</style>
