---
const { title, rating } = Astro.props;
---
<div class="review-callout my-8 border border-mint-500/30 bg-mint-900/10 rounded-lg p-6 relative overflow-hidden">
    <div class="flex items-center justify-between mb-4">
        <h3 class="text-xl font-bold text-mint-400 m-0">{title}</h3>
        <span class="px-3 py-1 bg-mint-500/20 text-mint-300 rounded-full text-sm font-semibold border border-mint-500/30">
            {rating}
        </span>
    </div>
    <div class="prose prose-invert max-w-none text-gray-300">
        <slot />
    </div>
</div>
